*.o
*.crf
*.d
*.lst
*.lnp
*.dep
*.map
*.axf
*.hex
*.htm
*.build_log.htm
*.sct
*.scvd
*.uvguix.*
*.iex

# Build output directories
Output/
Objects/
Listings/
DebugConfig/
RTE/

# JLink / ST-Link settings
*.jlink
JLinkLog.txt
JLinkSettings.ini

# ============================================
# IDE & Editor
# ============================================

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================
# Large Binary Files & Archives
# ============================================

# Compressed archives
*.rar
*.zip
*.7z
*.tar.gz

# Word documents (binary, not version-control friendly)
*.doc
*.docx

# ============================================
# Project-specific: exclude large directories
# ============================================

# Software tools (large installers)
所需软件/

# Report videos (very large binary files)
报告视频/

# ============================================
# Template-specific build artifacts at root
# ============================================

